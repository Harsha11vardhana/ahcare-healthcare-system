# =============================================
# AHCare v7.0 — Environment Configuration
# =============================================
# Copy this file to .env and fill in values
# Never commit .env to version control

# Server
PORT=5000
NODE_ENV=development

# MongoDB (leave blank to run in offline/demo mode)
MONGO_URI=mongodb://localhost:27017/ahcare

# JWT Secret (change in production!)
JWT_SECRET=ahcare_super_secret_jwt_key_change_in_prod

# Optional: Anthropic API Key (for enhanced AI responses)
# Get from https://console.anthropic.com
ANTHROPIC_API_KEY=

# Optional: Google TTS API Key (for higher-quality Kannada TTS)
# Get from https://console.cloud.google.com
GOOGLE_TTS_API_KEY=

# CORS origin (set to your production domain)
CORS_ORIGIN=http://localhost:5000

# =============================================
# Voice AI Settings
# =============================================
# Uses Web Speech API by default (no key needed)
# Upgrade to Google Cloud Speech for production Kannada STT
GOOGLE_SPEECH_KEY=
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=centralindia
